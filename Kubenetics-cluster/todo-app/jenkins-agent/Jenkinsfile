pipeline {
  agent {
    label 'todo-agent'
  }

  environment {
    IMAGE_NAME = 'tinfoilhatxo/todo-app'  // Docker image name must be lowercase.
    REGISTRY_CREDENTIALS = 'docker-hub'
  }

  stages {
    stage('Checkout Code') {
      steps {
        // Checkout the 'anand' branch from your GitHub repository.
        git branch: 'anand', url: 'https://github.com/Anand-cmd-art/Kubernetics-Project'
      }
    }

    stage('List Workspace') {
      steps {
        // List directories to verify the repository structure.
        sh 'find . -type d -print'
      }
    }

    stage('Build Docker Image') {
      steps {
        script {
          // Build the image using the "Kubenetics-cluster/todo-app" directory as context.
          sh "docker build -t ${IMAGE_NAME} ./Kubenetics-cluster/todo-app"
        }
      }
    }

    stage('Push to Docker Hub') {
      steps {
        script {
          def img = docker.build("${IMAGE_NAME}", "./Kubenetics-cluster/todo-app")
          docker.withRegistry('', REGISTRY_CREDENTIALS) {
            sh "docker push ${IMAGE_NAME}:latest"
          }
        }
      }
    }

    stage('Deploy Todo App to Kubernetes') {
      steps {
        // Deploy or upgrade the local "todo-app" chart in "./Kubenetics-cluster/todo-app/helm".
        sh '''
          helm upgrade --install todo-app \
            ./Kubenetics-cluster/todo-app/helm \
            --namespace default \
            --set service.port=3005
        '''
      }
    }

    stage('Deploy Grafana to Kubernetes') {
      steps {
        // Use the OFFICIAL 'grafana/grafana' chart from the 'grafana' repo
        sh '''
          helm upgrade --install grafana \
            grafana/grafana \
            --namespace default \
            --set service.port=3000
        '''
      }
    }

    stage('Deploy Prometheus to Kubernetes') {
      steps {
        // Same approach for Prometheus: 'prometheus-community/prometheus'
        sh '''
          helm upgrade --install prometheus \
            prometheus-community/prometheus \
            --namespace default \
            --set server.port=9090
        '''
      }
    }
  }

  post {
    success {
      echo 'Pipeline executed successfully. Check your deployments in Kubernetes!'
    }
    failure {
      echo 'Pipeline failed. Please check the logs and redeploy.'
    }
  }
}
