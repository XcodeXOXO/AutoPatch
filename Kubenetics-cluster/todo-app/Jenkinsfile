pipeline {
  agent any

  environment {
    IMAGE_NAME = 'anandganesh/todo-app'  // Docker image name must be lowercase.
    REGISTRY_CREDENTIALS = '6a5dc436-fc93-4237-a727-af387e888ba4'
  }

  stages {
    stage('Checkout Code') {
      steps {
        // Check out the 'anand' branch from your GitHub repository.
        git branch: 'anand', url: 'https://github.com/Anand-cmd-art/Kubernetics-Project'
      }
    }
    
    stage('Build Docker Image') {
      steps {
        // Build the Docker image using the Dockerfile in the root directory.
        // This requires Docker to be installed on the Jenkins node.
        sh "docker build -t ${IMAGE_NAME} ."
      }
    }
    
    stage('Push to Docker Hub') {
      steps {
        script {
          // Authenticate to Docker Hub and push the image with the "latest" tag.
          docker.withRegistry('', REGISTRY_CREDENTIALS) {
            sh "docker push ${IMAGE_NAME}:latest"
          }
        }
      }
    }
    
    stage('Deploy to Kubernetes') {
      steps {
        // Deploy or upgrade the release using Helm.
        sh 'helm upgrade --install todo-app ./helm --namespace default'
      }
    }
  }
}
