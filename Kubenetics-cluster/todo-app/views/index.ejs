<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>To-Do List</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <h1>My To-Do List</h1>
        <nav>
            <a href="/">Home</a>
            <a href="/add">Add To-Do</a>
            <a href="/about">About</a>
        </nav>
    </header>
    <main>
        <% if(todos.length === 0) { %>
            <p>No to-do items yet. Add one!</p>
        <% } else { %>
            <ul>
                <% todos.forEach(function(todo) { %>
                    <li><%= todo %></li>
                <% }); %>
            </ul>
        <% } %>
    </main>
    <footer>
        <p>&copy; 2025 ToDo App</p>
    </footer>
    <script src="/js/main.js"></script>
</body>
</html>
