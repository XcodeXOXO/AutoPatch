pipeline {
  agent {
    label 'todo-agent'
  }

  environment {
    IMAGE_NAME = 'anandganesh/todo-app'  // Docker image name must be lowercase.
    REGISTRY_CREDENTIALS = '6a5dc436-fc93-4237-a727-af387e888ba4'
  }

  stages {
    stage('Checkout Code') {
      steps {
        // Checkout the 'anand' branch from your GitHub repository.
        git branch: 'anand', url: 'https://github.com/Anand-cmd-art/Kubernetics-Project'
      }
    }
    
    stage('Build Docker Image') {
      steps {
        script {
          // If your Dockerfile is in the "todo-app" directory, use that as the build context.
          sh "docker build -t ${IMAGE_NAME} todo-app"
        }
      }
    }
    
    stage('Push to Docker Hub') {
      steps {
        script {
          // Authenticate to Docker Hub using the provided credentials and push the image.
          docker.withRegistry('', REGISTRY_CREDENTIALS) {
            sh "docker push ${IMAGE_NAME}:latest"
          }
        }
      }
    }
    
    stage('Deploy to Kubernetes') {
      steps {
        // Deploy (or upgrade) your application using Helm.
        sh 'helm upgrade --install todo-app ./helm --namespace default'
      }
    }
  }
}
